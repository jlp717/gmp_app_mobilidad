#!/usr/bin/env bash
# Pre-commit hook: Scan for hardcoded secrets before allowing commit
# Install: cp .husky/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

echo "🔒 Running security scan..."

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

FOUND=0

# 1. Check for default/fallback secrets in JS/TS files
echo "  Checking for hardcoded secrets..."
SECRET_PATTERNS=(
  "default-secret"
  "dev-access-secret"
  "dev-refresh-secret"
  "change-in-production"
  "your-secret-key"
  "your-secret-here"
  "supersecret"
  "password123"
  "API_KEY_HERE"
  "YOUR_API_KEY"
  "sk-live-"
  "pk-live-"
)

for pattern in "${SECRET_PATTERNS[@]}"; do
  # Exclude security checks (=== comparisons) and test files
  MATCHES=$(grep -rn "$pattern" backend/src --include="*.js" --include="*.ts" 2>/dev/null | grep -v ".test." | grep -v "__tests__" | grep -v "node_modules" | grep -v "===" | grep -v "!==" || true)
  if [ -n "$MATCHES" ]; then
    echo -e "${RED}❌ Found hardcoded secret pattern: $pattern${NC}"
    echo "$MATCHES"
    FOUND=1
  fi
done

# 2. Check for .env files committed
echo "  Checking for committed .env files..."
ENV_FILES=$(git diff --cached --name-only | grep -E "\.env$|\.env\.(local|production|staging)$" 2>/dev/null || true)
if [ -n "$ENV_FILES" ]; then
  echo -e "${RED}❌ Attempting to commit .env files:${NC}"
  echo "$ENV_FILES"
  FOUND=1
fi

# 3. Check for private keys
echo "  Checking for private keys..."
if grep -rn "BEGIN.*PRIVATE KEY" . --include="*.pem" --include="*.key" --include="*.txt" 2>/dev/null | grep -v "node_modules" | grep -v ".git"; then
  echo -e "${RED}❌ Found private key files${NC}"
  FOUND=1
fi

# 4. Check for AWS/Google/GitHub tokens
echo "  Checking for cloud provider tokens..."
CLOUD_PATTERNS=(
  "AKIA[0-9A-Z]{16}"
  "AIza[0-9A-Za-z\\-_]{35}"
  "ghp_[0-9a-zA-Z]{36}"
  "glpat-[0-9a-zA-Z\\-_]{20}"
)

for pattern in "${CLOUD_PATTERNS[@]}"; do
  if grep -rnE "$pattern" . --include="*.js" --include="*.ts" --include="*.dart" --include="*.json" 2>/dev/null | grep -v "node_modules" | grep -v ".git"; then
    echo -e "${RED}❌ Found cloud provider token pattern${NC}"
    FOUND=1
  fi
done

# 5. Check for credentials in connection strings
echo "  Checking for credentials in connection strings..."
if grep -rnE "(mongodb|postgres|mysql|redis)://[^:]+:[^@]+@" . --include="*.js" --include="*.ts" --include="*.dart" 2>/dev/null | grep -v "node_modules" | grep -v ".git" | grep -v "process.env" | grep -v "test"; then
  echo -e "${RED}❌ Found credentials in connection strings${NC}"
  FOUND=1
fi

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo -e "${RED}🚫 SECURITY SCAN FAILED${NC}"
  echo -e "${YELLOW}Remove all hardcoded secrets before committing.${NC}"
  echo -e "${YELLOW}Use environment variables (.env files, GitHub Secrets, etc.) instead.${NC}"
  echo ""
  echo "To bypass this check (NOT RECOMMENDED):"
  echo "  git commit --no-verify"
  exit 1
fi

echo -e "${GREEN}✅ Security scan passed - no hardcoded secrets found${NC}"
exit 0
