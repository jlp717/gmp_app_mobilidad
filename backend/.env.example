# GMP App Mobilidad - Backend Environment Configuration
# Copy this file to .env and fill in the values
# NEVER commit .env to version control

# ─── Server ──────────────────────────────────────────────
NODE_ENV=development
PORT=3334
HOST=0.0.0.0

# ─── Database (DB2 via ODBC) ─────────────────────────────
ODBC_DSN=GMP
ODBC_UID=
ODBC_PWD=
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_POOL_INCREMENT=2
DB_POOL_TIMEOUT=30
DB_KEEP_ALIVE_INTERVAL=120
DB_MAX_RETRIES=3
DB_RETRY_DELAY=1000

# ─── Authentication (MUST be 32+ characters) ─────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=7d
BCRYPT_ROUNDS=12
MAX_SESSIONS_PER_USER=5
LOCKOUT_THRESHOLD=5
LOCKOUT_DURATION=900000

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_KEY_PREFIX=gmp:
REDIS_TTL_SHORT=300
REDIS_TTL_MEDIUM=1800
REDIS_TTL_LONG=86400
REDIS_TTL_REALTIME=60
REDIS_TTL_JEFE=600
REDIS_TTL_COMERCIAL=1800
REDIS_TTL_REPARTIDOR=900

# ─── CORS ────────────────────────────────────────────────
CORS_ORIGIN=*

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_GLOBAL_WINDOW=900000
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_LOGIN_WINDOW=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_COBROS_WINDOW=900000
RATE_LIMIT_COBROS_MAX=30
RATE_LIMIT_PEDIDOS_WINDOW=900000
RATE_LIMIT_PEDIDOS_MAX=50

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=combined
LOG_FILE=logs/app.log

# ─── Email (SMTP) ────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gmpapp.com

# ─── App Config ──────────────────────────────────────────
COMPANY_NAME=Granja Mari Pepa
MIN_YEAR=2020
GOOGLE_MAPS_API_KEY=
