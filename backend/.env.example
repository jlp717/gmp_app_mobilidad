# ====================================================================
# CONFIGURACIÓN DEL BACKEND - GMP APP UNIFIED
# SECURITY HARDENED CONFIGURATION
# ====================================================================
# IMPORTANT: Copy this file to .env and replace ALL placeholder values
# Never commit .env file to version control!
# ====================================================================

# =============================================================================
# ENTORNO
# =============================================================================
NODE_ENV=development
PORT=3334
HOST=0.0.0.0

# =============================================================================
# BASE DE DATOS (IBM i ODBC)
# =============================================================================
# El DSN "GMP" debe existir en Windows ODBC
# Use Windows Credential Manager or environment variables for production
ODBC_DSN=GMP
ODBC_UID=<TU_USUARIO_IBM_I>
ODBC_PWD=<TU_PASSWORD_IBM_I>
ODBC_POOL_MIN=5
ODBC_POOL_MAX=50
ODBC_POOL_IDLE_TIMEOUT=30000
ODBC_POOL_ACQUIRE_TIMEOUT=30000

# =============================================================================
# JWT - AUTENTICACIÓN (SECURITY CRITICAL)
# =============================================================================
# GENERATE STRONG SECRETS: Use at least 32 random characters
# Linux/Mac: openssl rand -hex 32
# Windows: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=<GENERAR_CON_OPENSSL_RAND_HEX_32>
JWT_REFRESH_SECRET=<GENERAR_CON_OPENSSL_RAND_HEX_32>
JWT_ACCESS_EXPIRES=1h
JWT_REFRESH_EXPIRES=7d

# =============================================================================
# REDIS - CACHING
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=<REDIS_PASSWORD_SI_REQUERIDO>
REDIS_TTL_DEFAULT=3600
REDIS_TTL_PRODUCTS=86400
REDIS_TTL_PROMOTIONS=1800

# =============================================================================
# CORS - ORIGENES PERMITIDOS
# =============================================================================
# Production: Specify exact origins (no wildcards!)
# Development: Use '*' or 'true' for all origins
CORS_ORIGINS=https://app.mari-pepa.com,https://movilidad.mari-pepa.com

# =============================================================================
# SEGURIDAD - PASSWORD HASHING
# =============================================================================
# Bcrypt salt rounds (12 = good balance of security/performance)
# Higher = more secure but slower (max recommended: 14)
BCRYPT_ROUNDS=12

# =============================================================================
# SEGURIDAD - RATE LIMITING
# =============================================================================
# Login attempt limits (brute force protection)
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=30

# API rate limits
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT=5
API_RATE_LIMIT=500

# Session management
MAX_SESSIONS_PER_USER=5
SESSION_TTL=3600

# =============================================================================
# EMAIL - SMTP
# =============================================================================
SMTP_HOST=mail.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASSWORD=<SMTP_PASSWORD_SEGURO>
SMTP_FROM=noreply@example.com

# Planner Emails (notificaciones de cambios de ruta)
# Set to 'true' to disable all planner notification emails
DISABLE_PLANNER_EMAILS=false

# =============================================================================
# EMPRESA
# =============================================================================
EMPRESA_NOMBRE=Granja Mari Pepa
EMPRESA_CIF=B04008710
EMPRESA_TELEFONO=639 77 86 56
EMPRESA_EMAIL=pedidos@mari-pepa.com

# =============================================================================
# FRONTEND URL (para enlaces en emails)
# =============================================================================
FRONTEND_URL=https://app.mari-pepa.com

# =============================================================================
# GOOGLE MAPS
# =============================================================================
GOOGLE_MAPS_API_KEY=<TU_GOOGLE_MAPS_API_KEY>

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=info
LOG_FORMAT=combined

# =============================================================================
# CIRCUIT BREAKER
# =============================================================================
CIRCUIT_BREAKER_TIMEOUT=15000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# =============================================================================
# TYPEROUTES (TypeScript Routes)
# =============================================================================
# Set to 'true' to use compiled TypeScript routes from dist/
# Set to 'false' to use legacy JavaScript routes
USE_TS_ROUTES=true

# =============================================================================
# DDD MODULE ROUTES
# =============================================================================
# Set to 'true' to enable Domain-Driven Design module routes
# Set to 'false' to use flat route structure
USE_DDD_ROUTES=false

# =============================================================================
# EXPRESS BODY PARSING LIMITS
# =============================================================================
# Maximum request body size (default: 5MB)
MAX_CONTENT_LENGTH=5242880
